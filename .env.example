NODE_ENV=development
PORT=5000

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/first_psql?schema=public

JWT_ACCESS_SECRET=change-this-access-secret
JWT_REFRESH_SECRET=change-this-refresh-secret
JWT_ACCESS_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=30d
JWT_REFRESH_COOKIE_PATH=/api/v1/auth/refresh-token
JWT_ACCESS_COOKIE_NAME=accessToken
JWT_REFRESH_COOKIE_NAME=refreshToken
